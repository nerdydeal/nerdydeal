---
const {
  number,
  name,
  bestFor,
  description,
  pros = [],
  cons = [],
  priceNote = "Check current price",
  buttonText = "Check price on Amazon",
  url = "#",
  asin = "",
  image = "",
  imageAlt = "",
} = Astro.props;

const hasRealUrl = url && url !== "#";
const hasImage = Boolean(image);
const safeImageAlt = imageAlt || name || "Product image";
---

<article class="product-card" data-asin={asin || undefined}>
  {hasImage && (
    <div class="product-image-wrap">
      <img
        class="product-image"
        src={image}
        alt={safeImageAlt}
        loading="lazy"
        decoding="async"
      />
    </div>
  )}

  <div class="product-content">
    {number && <p class="product-number">{number}</p>}

    <div class="product-heading">
      <div>
        <h2>{name}</h2>
        {bestFor && <p class="best-for">Best for: {bestFor}</p>}
      </div>
    </div>

    {description && <p class="description">{description}</p>}

    {(pros.length > 0 || cons.length > 0) && (
      <div class="product-lists">
        {pros.length > 0 && (
          <div>
            <h3>Why it works</h3>
            <ul>
              {pros.map((item) => <li>{item}</li>)}
            </ul>
          </div>
        )}

        {cons.length > 0 && (
          <div>
            <h3>Watch-outs</h3>
            <ul>
              {cons.map((item) => <li>{item}</li>)}
            </ul>
          </div>
        )}
      </div>
    )}

    <div class="product-action">
      <p>{priceNote}</p>

      {hasRealUrl && (
        <a
          href={url}
          rel="sponsored nofollow noopener"
          target="_blank"
        >
          {buttonText}
        </a>
      )}
    </div>

    <p class="affiliate-note">
      Affiliate note: NerdyDeal may earn from qualifying purchases.
    </p>
  </div>
</article>

<style>
  .product-card {
    margin: 34px 0;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 24px;
    background:
      linear-gradient(
        180deg,
        rgba(255, 255, 255, 0.07),
        rgba(255, 255, 255, 0.035)
      );
    box-shadow: 0 20px 70px rgba(0, 0, 0, 0.22);
  }

  .product-image-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 260px;
    padding: 24px;
    background: rgba(255, 255, 255, 0.04);
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  .product-image {
    display: block;
    width: 100%;
    max-width: 520px;
    max-height: 360px;
    object-fit: contain;
    border-radius: 16px;
  }

  .product-content {
    padding: 28px;
  }

  .product-number {
    margin: 0 0 12px;
    color: #d90000;
    font-weight: 950;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .product-heading {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 24px;
  }

  h2 {
    margin: 0;
    color: #f4f4f4;
    font-size: clamp(1.7rem, 4vw, 2.8rem);
    line-height: 1;
    letter-spacing: -0.055em;
  }

  .best-for {
    margin: 12px 0 0;
    color: #d90000;
    font-weight: 900;
  }

  .description,
  li,
  .product-action p,
  .affiliate-note {
    color: #d8d8d8;
    line-height: 1.7;
  }

  .description {
    margin: 20px 0 0;
  }

  .product-lists {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 18px;
    margin-top: 22px;
  }

  h3 {
    margin: 0 0 10px;
    color: #ffffff;
    font-size: 1rem;
  }

  ul {
    margin: 0;
    padding-left: 1.2rem;
  }

  .product-action {
    margin-top: 24px;
    padding-top: 22px;
    border-top: 1px solid rgba(217, 0, 0, 0.24);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
    flex-wrap: wrap;
  }

  .product-action p {
    margin: 0;
    font-weight: 800;
  }

  .product-action a {
    display: inline-flex;
    min-height: 46px;
    align-items: center;
    justify-content: center;
    padding: 0 18px;
    border-radius: 999px;
    background: #d90000;
    color: #ffffff;
    font-weight: 950;
    text-decoration: none;
  }

  .product-action a:hover {
    background: #ff1d1d;
  }

  .product-action a:focus-visible {
    outline: 3px solid #ffffff;
    outline-offset: 3px;
  }

  .affiliate-note {
    margin: 18px 0 0;
    font-size: 0.9rem;
    color: #a8a8a8;
  }

  @media (max-width: 680px) {
    .product-content {
      padding: 22px;
    }

    .product-image-wrap {
      min-height: 200px;
      padding: 18px;
    }

    .product-lists {
      grid-template-columns: 1fr;
    }
  }
</style>