---
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<header class="site-header">
  <a class="logo-link" href={`${base}/`} aria-label="NerdyDeal home">
  <img
    class="site-logo"
    src={`${base}/nerdydeal-logo.png`}
    alt="NerdyDeal"
    width="300"
    height="208"
  />
</a>

  <nav class="main-nav" aria-label="Main navigation">
    <a href={`${base}/`}>Home</a>
    <a href={`${base}/posts/`}>Latest Finds</a>
    <a href={`${base}/affiliate-disclosure/`}>Disclosure</a>
  </nav>
</header>

<style>
  .site-header {
    width: 100%;
    margin: 0;
    padding: 12px max(32px, calc((100vw - 1180px) / 2));
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    background:
      linear-gradient(180deg, #1c1c1c 0%, #121212 100%);
    border-bottom: 2px solid rgba(217, 0, 0, 0.65);
    box-shadow: 0 10px 28px rgba(0, 0, 0, 0.34);
  }

  .logo-link {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    color: #f7f2ff;
    text-decoration: none;
    font-weight: 950;
  }

  .site-logo {
    display: block;
    width: 142px;
    height: auto;
    filter: drop-shadow(0 8px 14px rgba(0, 0, 0, 0.55));
  }

  .main-nav {
    display: flex;
    align-items: center;
    gap: 18px;
    flex-wrap: wrap;
  }

  .main-nav a {
    color: #ddd7f3;
    text-decoration: none;
    font-weight: 800;
    font-size: 0.95rem;
  }

  .main-nav a:hover {
    color: #d90000;
  }

  @media (max-width: 720px) {
    .site-header {
      align-items: flex-start;
      flex-direction: column;
    }

    .main-nav {
      gap: 14px;
    }
  }
</style>