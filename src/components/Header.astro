---
const base = import.meta.env.BASE_URL;
---

<header class="site-header">
  <a class="logo-link" href={base} aria-label="NerdyDeal home">
  <img
    class="site-logo"
    src={`${base}/nerdydeal-logo.png`}
    alt="NerdyDeal"
    width="300"
    height="208"
  />
</a>

  <nav class="main-nav" aria-label="Main navigation">
    <a href={base}>Home</a>
    <a href={`${base}posts/weird-desk-gadgets/`}>Latest Finds</a>
    <a href={`${base}affiliate-disclosure/`}>Disclosure</a>
  </nav>
</header>

<style>
  .site-header {
    width: min(1180px, calc(100% - 32px));
    margin: 0 auto;
    padding: 22px 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
  }

  .logo-link {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    color: #f7f2ff;
    text-decoration: none;
    font-weight: 950;
  }

    .site-logo {
    display: block;
    width: 172px;
    height: auto;
    filter: drop-shadow(0 12px 22px rgba(0, 0, 0, 0.45));
  }

  .main-nav {
    display: flex;
    align-items: center;
    gap: 18px;
    flex-wrap: wrap;
  }

  .main-nav a {
    color: #ddd7f3;
    text-decoration: none;
    font-weight: 800;
    font-size: 0.95rem;
  }

  .main-nav a:hover {
    color: #d90000;
  }

  @media (max-width: 720px) {
    .site-header {
      align-items: flex-start;
      flex-direction: column;
    }

    .main-nav {
      gap: 14px;
    }
  }
</style>