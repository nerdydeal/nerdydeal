---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const {
  title = "NerdyDeal | Weird Useful Finds, Tech Gear & Nerd Stuff Worth Buying",
  description = "NerdyDeal finds weird useful products, nerdy gear, desk gadgets, PC build ideas, DND finds, gaming accessories, anime gifts, and oddly specific stuff worth buying.",
} = Astro.props;

const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <link rel="icon" href={`${base}favicon.ico`} />
    <meta name="viewport" content="width=device-width" />

    <title>{title}</title>
    <meta name="description" content={description} />
  </head>

  <body>
    <Header />

    <slot />

    <Footer />
  </body>
</html>

<style is:global>
  :root {
    color-scheme: dark;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      sans-serif;
    background: #090909;
    color: #f4f4f4;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    min-height: 100vh;
    background:
      radial-gradient(circle at top left, rgba(255, 255, 255, 0.11), transparent 28rem),
      radial-gradient(circle at top right, rgba(190, 0, 0, 0.22), transparent 30rem),
      linear-gradient(135deg, #080808 0%, #151515 48%, #050505 100%);
  }

  a {
    color: inherit;
  }
</style>