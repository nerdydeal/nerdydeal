---
import BaseLayout from "../layouts/BaseLayout.astro";

const base = import.meta.env.BASE_URL;
---

<BaseLayout
  title="Affiliate Disclosure | NerdyDeal"
  description="Affiliate disclosure for NerdyDeal, including information about Amazon Associates and affiliate links."
>
  <main class="page">
    <a class="back-link" href={base}>← Back to NerdyDeal</a>

    <article>
      <p class="eyebrow">Disclosure</p>
      <h1>Affiliate Disclosure</h1>

      <p>
        NerdyDeal may earn commissions from qualifying purchases made through
        links on this website.
      </p>

      <p>
        As an Amazon Associate, NerdyDeal earns from qualifying purchases. Some
        links on this site may be affiliate links, which means we may receive a
        commission if you click a link and make a purchase.
      </p>

      <p>
        This does not change the price you pay. It helps support the site and
        allows us to keep finding weird, useful, nerdy, and oddly specific
        products worth talking about.
      </p>

      <p>
        NerdyDeal aims to recommend products based on usefulness, fit,
        interesting design, buyer intent, and practical value. We do not claim
        hands-on testing unless an article specifically says we tested the
        product ourselves.
      </p>
    </article>
  </main>
</BaseLayout>

<style>
  .page {
    width: min(850px, calc(100% - 32px));
    margin: 0 auto;
    padding: 48px 0 72px;
  }

  .back-link {
    color: #d90000;
    font-weight: 800;
    text-decoration: none;
  }

  .back-link:hover {
    color: #ffffff;
  }

  article {
    margin-top: 42px;
  }

  .eyebrow {
    color: #d90000;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  h1 {
    margin: 0 0 24px;
    font-size: clamp(3rem, 8vw, 6rem);
    line-height: 0.92;
    letter-spacing: -0.07em;
  }

  p {
    color: #d8d8d8;
    line-height: 1.75;
    font-size: 1.1rem;
  }
</style>