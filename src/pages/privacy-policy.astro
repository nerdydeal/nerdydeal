---
import BaseLayout from "../layouts/BaseLayout.astro";

const base = import.meta.env.BASE_URL;
---

<BaseLayout
  title="Privacy Policy | NerdyDeal"
  description="Privacy policy for NerdyDeal, including information about analytics, affiliate links, cookies, and third-party services."
>
  <main class="page">
    <a class="back-link" href={base}>← Back to NerdyDeal</a>

    <article>
      <p class="eyebrow">Privacy</p>
      <h1>Privacy Policy</h1>

      <p>
        NerdyDeal respects your privacy. This page explains what information may
        be collected when you visit this website and how it may be used.
      </p>

      <h2>Information we may collect</h2>
      <p>
        NerdyDeal may collect basic website usage information, such as pages
        visited, referring websites, device type, browser type, approximate
        location, and general traffic patterns.
      </p>

      <h2>Analytics</h2>
      <p>
        NerdyDeal may use analytics tools to understand how visitors use the
        site, which pages are popular, and how people find our content. This
        helps us improve articles, product guides, and recommendations.
      </p>

      <h2>Affiliate links</h2>
      <p>
        Some links on NerdyDeal may be affiliate links. If you click an
        affiliate link and make a purchase, NerdyDeal may earn a commission.
        Affiliate partners may use cookies or similar technologies to track
        referrals and qualifying purchases.
      </p>

      <h2>Amazon Associates</h2>
      <p>
        As an Amazon Associate, NerdyDeal earns from qualifying purchases.
        Amazon and other affiliate partners may collect information according to
        their own privacy policies when you visit their websites.
      </p>

      <h2>Cookies</h2>
      <p>
        NerdyDeal may use cookies or similar technologies for analytics,
        affiliate tracking, site functionality, or future features such as saved
        finds or notification preferences.
      </p>

      <h2>Third-party websites</h2>
      <p>
        NerdyDeal links to third-party websites, including retailers and
        affiliate partners. We are not responsible for the privacy practices,
        content, or policies of those third-party websites.
      </p>

      <h2>Contact</h2>
      <p>
        If you have questions about this privacy policy, you can contact
        NerdyDeal through the contact method listed on this website.
      </p>

      <p class="updated">Last updated: July 2026</p>
    </article>
  </main>
</BaseLayout>

<style>
  .page {
    width: min(850px, calc(100% - 32px));
    margin: 0 auto;
    padding: 48px 0 72px;
  }

  .back-link {
    color: #d90000;
    font-weight: 800;
    text-decoration: none;
  }

  .back-link:hover {
    color: #ffffff;
  }

  article {
    margin-top: 42px;
  }

  .eyebrow {
    color: #d90000;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  h1 {
    margin: 0 0 24px;
    font-size: clamp(3rem, 8vw, 6rem);
    line-height: 0.92;
    letter-spacing: -0.07em;
  }

  h2 {
    margin-top: 34px;
    color: #f4f4f4;
  }

  p {
    color: #d8d8d8;
    line-height: 1.75;
    font-size: 1.1rem;
  }

  .updated {
    margin-top: 40px;
    color: #d90000;
    font-weight: 800;
  }
</style>