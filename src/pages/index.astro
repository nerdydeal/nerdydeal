---
import BaseLayout from "../layouts/BaseLayout.astro";

const base = import.meta.env.BASE_URL;

const latestPosts = [
  {
    title: "10 Weird Desk Gadgets That Actually Make Sense",
    description:
      "Odd little desk upgrades that are useful, conversation-worthy, and not just plastic clutter wearing a fake mustache.",
    href: `${base}/posts/weird-desk-gadgets/`,
    category: "Desk Gadgets",
  },
  {
    title: "Best Mini PCs for a Home AI Server in 2026",
    description:
      "A practical guide for running local AI, media tools, automation, and home-server experiments without building a furnace.",
    href: "#",
    category: "Home Tech",
  },
  {
    title: "DND Gifts That Are Actually Useful at the Table",
    description:
      "Dice towers, initiative trackers, spell tools, and tabletop gear that will not be banished to the junk drawer.",
    href: "#",
    category: "DND",
  },
  {
    title: "Gaming Desk Accessories That Pull Their Weight",
    description:
      "Useful upgrades for cleaner setups, better cable control, and a desk that feels less like a dragon nest.",
    href: "#",
    category: "Gaming",
  },
  {
    title: "Weird Finds Under $25 That Feel Illegal to Ignore",
    description:
      "Small, strange, useful products that scratch the ancient bargain-hunter part of the brain.",
    href: "#",
    category: "Weird Finds",
  },
];
---

<BaseLayout>
  <main>
    <section class="hero">
      <div class="hero-content">
        <p class="eyebrow">Useful stuff. Weird stuff. Stuff your desk might ask for.</p>

        <h1>NerdyDeal</h1>

        <p class="tagline">
          Weird useful finds, tech gear, gaming gadgets, DND loot, anime gifts,
          PC build ideas, and oddly specific products that make you say:
          <strong>“Wait... I actually need that.”</strong>
        </p>

        <div class="hero-actions">
          <a class="button primary" href="#latest-posts">Read latest finds</a>
          <a class="button secondary" href="#categories">Browse categories</a>
        </div>

        <p class="disclosure">
          Affiliate disclosure: NerdyDeal may earn from qualifying purchases through
          affiliate links, including Amazon Associates links.
        </p>
      </div>
    </section>

    <section class="section" id="categories">
      <div class="section-heading">
        <p class="eyebrow">The shelves</p>
        <h2>What NerdyDeal hunts for</h2>
      </div>

      <div class="category-grid">
        <article>
          <h3>Desk Gadgets</h3>
          <p>Useful little goblin tools for your workspace.</p>
        </article>

        <article>
          <h3>PC & Home Tech</h3>
          <p>Mini PCs, home servers, cables, storage, and setup upgrades.</p>
        </article>

        <article>
          <h3>Gaming & Anime</h3>
          <p>Gear, gifts, collectibles, accessories, and setup candy.</p>
        </article>

        <article>
          <h3>DND & Ren Faire</h3>
          <p>Tabletop tools, fantasy gear, dice things, leather things, shiny things.</p>
        </article>

        <article>
          <h3>3D Printing</h3>
          <p>Useful prints, printer accessories, resin tools, and workshop upgrades.</p>
        </article>

        <article>
          <h3>Weird Finds</h3>
          <p>Products from the “why does this exist, and why do I want it?” shelf.</p>
        </article>
      </div>
    </section>

    <section class="section spotlight">
      <div>
        <p class="eyebrow">Deal of the week</p>
        <h2>The weekly shiny object</h2>
        <p>
          Eventually this will be a live featured deal that can trigger social posts,
          Reddit drafts, and push notifications when it goes live. For now, this is
          the reserved pedestal.
        </p>
      </div>

      <a class="button primary" href="#">Coming soon</a>
    </section>

    <section class="section" id="latest-posts">
      <div class="section-heading">
        <p class="eyebrow">Fresh from the shelf</p>
        <h2>Latest posts</h2>
      </div>

      <div class="post-list">
        {latestPosts.map((post) => (
          <article class="post-card">
            <p class="post-category">{post.category}</p>
            <h3>
              <a href={post.href}>{post.title}</a>
            </h3>
            <p>{post.description}</p>
          </article>
        ))}
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  main {
    width: min(1180px, calc(100% - 32px));
    margin: 0 auto;
  }

  .hero {
    min-height: 68vh;
    display: grid;
    align-items: center;
    padding: 72px 0 56px;
  }

  .hero-content {
    max-width: 920px;
  }

  .eyebrow {
    color: #d90000;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  h1 {
    margin: 0;
    font-size: clamp(4.5rem, 14vw, 12rem);
    line-height: 0.82;
    letter-spacing: -0.09em;
  }

  h2 {
    margin: 0;
    font-size: clamp(2.2rem, 5vw, 4.8rem);
    line-height: 0.95;
    letter-spacing: -0.07em;
  }

  h3 {
    margin: 0;
    font-size: 1.35rem;
    line-height: 1.1;
  }

  .tagline {
    max-width: 760px;
    margin: 28px 0 0;
    color: #ddd7f3;
    font-size: clamp(1.15rem, 2vw, 1.55rem);
    line-height: 1.55;
  }

  .tagline strong {
    color: #fff7c7;
  }

  .hero-actions {
    margin-top: 32px;
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 0 20px;
    border-radius: 999px;
    font-weight: 900;
    text-decoration: none;
  }

  .button.primary {
    background: #d90000;
    color: #181225;
  }

  .button.secondary {
    border: 1px solid rgba(255, 255, 255, 0.22);
    color: #f7f2ff;
  }

  .disclosure {
    max-width: 680px;
    margin-top: 26px;
    color: #bfb8d8;
    font-size: 0.95rem;
    line-height: 1.6;
  }

  .section {
    padding: 64px 0;
  }

  .section-heading {
    margin-bottom: 28px;
  }

  .category-grid,
  .post-list {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 18px;
  }

  .category-grid article,
  .post-card,
  .spotlight {
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 26px;
    background: rgba(255, 255, 255, 0.055);
    box-shadow: 0 20px 80px rgba(0, 0, 0, 0.18);
  }

  .category-grid article,
  .post-card {
    padding: 24px;
  }

  .category-grid p,
  .post-card p,
  .spotlight p {
    color: #cfc8e8;
    line-height: 1.65;
  }

  .post-card a {
    color: #f7f2ff;
    text-decoration: none;
  }

  .post-card a:hover {
    color: #d90000;
  }

  .post-category {
    margin: 0 0 12px;
    color: #d90000 !important;
    font-size: 0.85rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .spotlight {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 28px;
    padding: 32px;
  }

  .spotlight p {
    max-width: 680px;
  }

  @media (max-width: 880px) {
    .category-grid,
    .post-list {
      grid-template-columns: 1fr 1fr;
    }

    .spotlight {
      align-items: flex-start;
      flex-direction: column;
    }
  }

  @media (max-width: 580px) {
    .category-grid,
    .post-list {
      grid-template-columns: 1fr;
    }
  }
</style>